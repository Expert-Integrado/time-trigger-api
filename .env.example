# MongoDB connection string (replica set)
MONGODB_URI=mongodb://user:password@host1:27017,host2:27018,host3:27019/?authSource=admin&replicaSet=rs0

# Cron interval in milliseconds (e.g., 10000 = 10 seconds)
CRON_INTERVAL=10000

# Timezone for morningLimit/nightLimit comparison
TZ=America/Sao_Paulo

# HTTP port (default: 3000)
PORT=3000
