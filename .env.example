# MongoDB connection string (replica set)
MONGODB_URI=mongodb://user:password@host1:27017,host2:27018,host3:27019/?authSource=admin&replicaSet=rs0

# Cron intervals in milliseconds — one per dispatch type (CRON-01/02/03)
# Runs + FUPs share the timeTrigger gate — typically the longest interval
CRON_INTERVAL_RUNS=30000

# FUP dispatch fires independently from runs
CRON_INTERVAL_FUP=15000

# Messages dispatch has no time gate — can fire more frequently
CRON_INTERVAL_MESSAGES=5000

# Timezone for morningLimit/nightLimit comparison
TZ=America/Sao_Paulo

# HTTP port (default: 3000)
PORT=3000

# Filter which databases to process (optional)
# * or absent = all eligible databases
# comma-separated list = only those databases
# Examples:
#   TARGET_DATABASES=*
#   TARGET_DATABASES=sdr-4blue
#   TARGET_DATABASES=sdr-4blue,dev,acade-system
TARGET_DATABASES=*
